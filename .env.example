# Gemini — free tier at aistudio.google.com
GEMINI_API_KEY=your_key_here

# Redis — use Upstash free tier (upstash.com)
# Format: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# MongoDB — use MongoDB Atlas free tier (mongodb.com)
# Format: mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agentos

# Web search — free tier at tavily.com
TAVILY_API_KEY=your_key_here

# App
FRONTEND_URL=http://localhost:5173
DEBUG=true